# Server
HOST=0.0.0.0
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://studio_pair:password@localhost:5432/studio_pair
DATABASE_POOL_SIZE=10

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=30

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@studiopair.app
SMTP_FROM_NAME=Studio Pair

# Push Notifications
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# External APIs
TMDB_API_KEY=
RAWG_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=
YOUTUBE_API_KEY=

# Storage
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Encryption
ENCRYPTION_MASTER_KEY=change-this-to-a-random-key
